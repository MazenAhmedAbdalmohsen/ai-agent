# ── Groq API ──────────────────────────────────────────────────────────────────
# Required. Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Model ─────────────────────────────────────────────────────────────────────
# Primary model (default: openai/gpt-oss-120b)
MODEL=openai/gpt-oss-120b

# Fallback model used when the primary model fails (optional)
FALLBACK_MODEL=llama-3.3-70b-versatile

# Max tokens per response
MAX_TOKENS=4096

# ── SerpAPI (optional) ────────────────────────────────────────────────────────
# Enables Google-powered web search. Get key at: https://serpapi.com/manage-api-key
# If not set, DuckDuckGo is used as a free fallback.
SERPAPI_KEY=your_serpapi_key_here

# ── PC Control Safety ─────────────────────────────────────────────────────────
# When true, mouse coordinates are clamped to screen bounds before execution.
ENABLE_SCREEN_SAFETY=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000